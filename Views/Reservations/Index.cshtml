@model IEnumerable<ASP_Ticket_Center.Data.Reservation>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create">Create New</a>
    }
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                Количество
          @*       @Html.DisplayNameFor(model => model.Quantity) *@
            </th>
            <th>
                Дата
                @* @Html.DisplayNameFor(model => model.RegisterDate) *@
            </th>
            <th>
                Потребител
                @* @Html.DisplayNameFor(model => model.Clients) *@
            </th>
            <th>
                Билет
               @*  @Html.DisplayNameFor(model => model.Tickets) *@
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Quantity)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RegisterDate)
            </td>
            <td>
                @* @Html.DisplayFor(modelItem => *@ @(item.Clients.UserName+" "+item.Clients.LastName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Tickets.Id)
            </td>
                <td>
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> 

                    @if (User.IsInRole("Admin")) {
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    < a asp - action = "Delete" asp - route - id = "@item.Id" > Delete </ a >}
                </td>
        </tr>
}
    </tbody>
</table>
