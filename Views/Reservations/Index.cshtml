@model IEnumerable<ASP_Ticket_Center.Data.Reservation>

@{
    ViewData["Title"] = "Резервации";
}

<h2 class="mb-4">📋 Резервации</h2>

@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">+ Нова резервация</a>
}

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Количество</th>
                    <th>Дата</th>
                    <th>Потребител</th>
                    <th>Билет</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="badge bg-info text-dark">
                                @item.Quantity
                            </span>
                        </td>

                        <td>
                            @item.RegisterDate.ToString("dd.MM.yyyy")
                        </td>

                        <td>
                            <strong>
                                @(item.Clients.UserName + " " + item.Clients.LastName)
                            </strong>
                        </td>

                        <td>
                            <span class="text-muted">
                                #@item.Tickets.Id
                            </span>
                        </td>

                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Details
                                </a>

                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-warning">
                                        Edit
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </a>
                                }

                               

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>